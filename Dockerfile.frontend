# 前端 Dockerfile
# 构建阶段
FROM node:22-alpine AS builder

WORKDIR /app

# 复制 package.json
COPY package*.json ./

# 安装依赖
RUN npm install

# 复制源代码
COPY src ./src
COPY index.html .
COPY vite.config.ts .
COPY tsconfig*.json .
COPY env.d.ts .

# 构建
RUN npm run build

# 运行阶段
FROM nginx:alpine

# 复制构建产物到 nginx 目录
COPY --from=builder /app/dist /usr/share/nginx/html

# 复制 nginx 配置文件
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
